@if (Visible)
{
    <div class="modal-backdrop" @onclick="Cancel">
        <div class="modal-box" @onclick:stopPropagation="true">
            <div class="modal-icon">⚠️</div>
            <h5 class="modal-title">নিশ্চিত করুন</h5>
            <p class="modal-body">@Message</p>
            <div class="modal-actions">
                <button class="btn btn-danger" @onclick="Confirm">
                    @ConfirmText
                </button>
                <button class="btn btn-secondary" @onclick="Cancel">
                    বাতিল করুন
                </button>
            </div>
        </div>
    </div>
}

@code {
    [Parameter] public bool Visible { get; set; }
    [Parameter] public string Message { get; set; } = "আপনি কি সত্যিই এটি মুছে ফেলতে চান?";
    [Parameter] public string ConfirmText { get; set; } = "মুছে ফেলুন";
    [Parameter] public EventCallback OnConfirm { get; set; }
    [Parameter] public EventCallback OnCancel { get; set; }

    private async Task Confirm() => await OnConfirm.InvokeAsync();
    private async Task Cancel() => await OnCancel.InvokeAsync();
}
