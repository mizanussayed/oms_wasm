@page "/orders/{Id:int}"
@inject IOrderService OrderSvc
@inject NavigationManager Nav
@inject SettingsService SettingsSvc
@inject IJSRuntime JS

<PageTitle>অর্ডার বিস্তারিত — অর্ডার ব্যবস্থাপনা</PageTitle>

<div class="page-header">
    <h1 class="page-title">অর্ডারের বিস্তারিত তথ্য</h1>
    <a href="/orders" class="btn btn-secondary">← ফিরে যান</a>
</div>

@if (_loading)
{
    <LoadingSpinner />
}
else if (_order is null)
{
    <div class="alert-error">অর্ডারটি পাওয়া যায়নি।</div>
}
else
{
    <div class="detail-card">
        <div class="detail-row">
            <span class="detail-label">আইডি</span>
            <span class="detail-value">#@_order.Id</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">অর্ডার নম্বর</span>
            <span class="detail-value order-no-large">@_order.OrderNo</span>
        </div>
        <div class="detail-row">
            <span class="detail-label">স্ট্যাটাস</span>
            <span class="detail-value">
                <span class="badge @GetStatusClass(_order.Status)">
                    @GetStatusLabel(_order.Status)
                </span>
            </span>
        </div>
        @if (!string.IsNullOrWhiteSpace(_order.PhoneNumber))
        {
            <div class="detail-row">
                <span class="detail-label">📱 ফোন</span>
                <span class="detail-value">@_order.PhoneNumber</span>
            </div>
        }
    </div>

    <div class="detail-actions">
        <a href="/orders/edit/@_order.Id" class="btn btn-primary">✏️ সম্পাদনা করুন</a>

        @if (!string.IsNullOrWhiteSpace(_order.PhoneNumber))
        {
            <button class="btn btn-whatsapp" @onclick="SendWhatsApp" disabled="@_sendingWA">
                @if (_sendingWA) { <span class="spinner-sm"></span> }
                else { <span>💬</span> }
                WhatsApp পাঠান
            </button>
        }

        <a href="/orders" class="btn btn-secondary">তালিকায় ফিরুন</a>
    </div>
}

@code {
    [Parameter] public int Id { get; set; }

    private Order? _order;
    private bool _loading = true;
    private bool _sendingWA = false;

    protected override async Task OnInitializedAsync()
    {
        _order = await OrderSvc.GetOrderByIdAsync(Id);
        _loading = false;
    }

    private async Task SendWhatsApp()
    {
        if (_order is null) return;
        _sendingWA = true;
        var url = await SettingsSvc.BuildWhatsAppUrlAsync(_order.PhoneNumber, _order.OrderNo);
        if (url is not null)
            await JS.InvokeVoidAsync("open", url, "_blank");
        _sendingWA = false;
    }

    private static string GetStatusLabel(OrderStatus s) => s switch
    {
        OrderStatus.Pending   => "অপেক্ষমাণ",
        OrderStatus.Done      => "সম্পন্ন",
        OrderStatus.Delivered => "ডেলিভার হয়েছে",
        _                     => s.ToString()
    };

    private static string GetStatusClass(OrderStatus s) => s switch
    {
        OrderStatus.Pending   => "badge-pending",
        OrderStatus.Done      => "badge-done",
        OrderStatus.Delivered => "badge-delivered",
        _                     => ""
    };
}
